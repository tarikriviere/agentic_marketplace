# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Smart Contracts (set after forge script Deploy) ────────────────────────
NEXT_PUBLIC_IDENTITY_REGISTRY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REPUTATION_REGISTRY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VALIDATION_REGISTRY=0x0000000000000000000000000000000000000000

# ── Monad Testnet ──────────────────────────────────────────────────────────
NEXT_PUBLIC_MONAD_RPC=https://testnet-rpc.monad.xyz

# ── x402 Facilitator ──────────────────────────────────────────────────────
# Server-side private key used to submit x402 payments on Monad
FACILITATOR_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_NEVER_COMMIT_THIS

# ── Marketplace ───────────────────────────────────────────────────────────
# EOA that receives x402 application fees
NEXT_PUBLIC_MARKETPLACE_WALLET=0x0000000000000000000000000000000000000000

# ── App URL ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── WalletConnect (optional, for production) ──────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id
